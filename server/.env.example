# ── Database (use a cloud PostgreSQL provider in production) ──────────────────
# Recommended: Neon (free) → https://neon.tech
#              Supabase    → https://supabase.com
#              Render DB   → https://render.com
DB_HOST=localhost
DB_PORT=5432
DB_NAME=h_roots
DB_USER=postgres
DB_PASSWORD=your_db_password

# Or use a full connection string (takes priority if set)
# DATABASE_URL=postgresql://user:password@host:5432/h_roots?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed Vercel frontend URL (no trailing slash)
CLIENT_URL=https://himalayan-roots.vercel.app

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_NUMBER=919910426826
